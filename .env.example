# ==========================================
# 1. CẤU HÌNH HỆ THỐNG LÕI (CORE)
# ==========================================
APP_NAME="TravelVN Website"
APP_URL="http://localhost:8000"
APP_ENV=local
APP_DEBUG=true

# ==========================================
# 2. CẤU HÌNH CƠ SỞ DỮ LIỆU (DATABASE)
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=travel_clean_test
DB_USER=root
DB_PASS=

# ==========================================
# 3. CẤU HÌNH GỬI EMAIL (SMTP GMAIL)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME= 
MAIL_PASSWORD= 
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS= 
MAIL_FROM_NAME="TravelVN Support"

# ==========================================
# 4. CẤU HÌNH CỔNG THANH TOÁN VNPAY (ĐÃ ĐỔI TÊN CHUẨN)
# ==========================================
VNP_TMN_CODE= 
VNP_HASH_SECRET= 
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_RETURN_URL="http://localhost:8000/payment/vnpay_return"